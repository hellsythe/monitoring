# Copia este archivo a .env y rellena los valores antes de desplegar.
# Nunca subas el archivo .env al repositorio.

# =============================================================================
# Grafana
# =============================================================================

# Credenciales del administrador de Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=cambia_esta_password_por_una_segura

# URL publica de Grafana, servida por Coolify/Traefik con HTTPS.
# Ejemplo: https://grafana.tudominio.com
GRAFANA_ROOT_URL=https://grafana.tudominio.com

# Dominio FQDN que Coolify inyecta a Traefik via labels.
# Debe coincidir con la variable SERVICE_FQDN_GRAFANA que Coolify espera.
# En Coolify esto se configura en la UI; en docker compose local no aplica.
SERVICE_FQDN_GRAFANA=grafana.tudominio.com

# Plugins de Grafana separados por coma (opcional).
# Ejemplo: grafana-clock-panel,grafana-simple-json-datasource
GRAFANA_PLUGINS=

# =============================================================================
# Alertmanager / notificaciones
# =============================================================================

# URL del webhook donde Alertmanager enviara las alertas.
# Formato JSON: https://prometheus.io/docs/alerting/latest/configuration/#webhook_config
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/TU/URL/WEBHOOK

# Opcional: receptor por email (si descomentas el bloque 'email' en
# alertmanager.yml). Si no usas SMTP, deja vacio.
SMTP_SMARTHOST=
SMTP_USERNAME=
SMTP_PASSWORD=
